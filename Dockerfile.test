FROM jrei/systemd-ubuntu:22.04

# Avoid prompts from apt
ENV DEBIAN_FRONTEND=noninteractive

# Install dependencies
RUN apt-get update && apt-get install -y \
    curl \
    tar \
    sudo \
    dbus-user-session \
    kmod \
    iproute2 \
    procps \
    && rm -rf /var/lib/apt/lists/*

# Create a non-root user
RUN useradd -m -s /bin/bash overseer && \
    echo "overseer ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# Install overseer from latest release
RUN OS=linux && \
    ARCH=$(uname -m) && \
    case "$ARCH" in \
      x86_64) ARCH="amd64" ;; \
      aarch64|arm64) ARCH="arm64" ;; \
    esac && \
    curl -sL "https://github.com/tacheraSasi/overseer/releases/latest/download/overseer-${OS}-${ARCH}.tar.gz" -o overseer.tar.gz && \
    tar xzf overseer.tar.gz && \
    mv overseer /usr/local/bin/overseer && \
    chmod +x /usr/local/bin/overseer && \
    rm overseer.tar.gz

# Copy the test script
COPY test_overseer.sh /home/overseer/test_overseer.sh
RUN chmod +x /home/overseer/test_overseer.sh && chown overseer:overseer /home/overseer/test_overseer.sh

# IMPORTANT: Do NOT set USER overseer here. 
# Systemd (PID 1) MUST run as root.
# We will run the tests as the overseer user inside the script.
