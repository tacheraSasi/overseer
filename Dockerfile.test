FROM ubuntu:22.04

# Avoid prompts from apt
ENV DEBIAN_FRONTEND=noninteractive

# Install dependencies: systemd, dbus, curl, sudo, etc.
RUN apt-get update && apt-get install -y \
    systemd \
    dbus-user-session \
    curl \
    tar \
    sudo \
    kmod \
    iproute2 \
    procps \
    && rm -rf /var/lib/apt/lists/*

# Create a non-root user
RUN useradd -m -s /bin/bash overseer && \
    echo "overseer ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# Set up environment for systemd --user
ENV XDG_RUNTIME_DIR=/run/user/1000
RUN mkdir -p /run/user/1000 && \
    chown overseer:overseer /run/user/1000 && \
    chmod 700 /run/user/1000

# Install overseer from latest release
RUN OS=linux && \
    ARCH=$(uname -m) && \
    case "$ARCH" in \
      x86_64) ARCH="amd64" ;; \
      aarch64|arm64) ARCH="arm64" ;; \
    esac && \
    curl -sL "https://github.com/tacheraSasi/overseer/releases/latest/download/overseer-${OS}-${ARCH}.tar.gz" -o overseer.tar.gz && \
    tar xzf overseer.tar.gz && \
    mv overseer /usr/local/bin/overseer && \
    chmod +x /usr/local/bin/overseer && \
    rm overseer.tar.gz

USER overseer
WORKDIR /home/overseer

# Copy the test script and make it executable
COPY test_overseer.sh /home/overseer/test_overseer.sh
RUN sudo chmod +x /home/overseer/test_overseer.sh

# Ensure dbus is available for the user
RUN mkdir -p /home/overseer/.config/systemd/user

# Use a simpler entrypoint that can run systemd if needed, 
# but for testing, we might just want to stay alive.
# However, overseer NEEDS systemd running.
# Let's try the standard systemd entrypoint for Ubuntu.
CMD ["/lib/systemd/systemd", "--log-level=info", "--unit=multi-user.target"]
